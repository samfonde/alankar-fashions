# ==============================================
# ALANKAR FASHIONS — environment configuration
# Copy to .env.local (dev) or set in Hostinger hPanel > Node.js > Environment variables
# ==============================================

# --- Base ---
NEXT_PUBLIC_BASE_URL=https://alankarfashions.com
BRAND_NAME=Alankar Fashions
CORS_ORIGINS=https://alankarfashions.com

# --- Supabase (Database + Auth + Storage) ---
# From: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # SERVER-ONLY — never expose to client

# --- Resend (Transactional email) ---
# From: https://resend.com/api-keys — also add DNS records for alankarfashions.com in Resend > Domains
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@alankarfashions.com
ADMIN_LOW_STOCK_EMAIL=admin@alankarfashions.com

# --- Razorpay (Payments) ---
# Test keys: rzp_test_* — Live keys: rzp_live_* (get from Dashboard > Keys)
# You can ALSO set these from Admin > Settings > Payment (overrides env)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=          # Same as RAZORPAY_KEY_ID; exposed to client for Razorpay JS

# --- Cron (for abandoned cart automation) ---
# Any long random string. Used by cron-job.org/GitHub Actions to hit /api/cron/abandoned-cart
CRON_SECRET=change_me_cron_secret_to_long_random_string

# --- Node ---
NODE_ENV=production
PORT=3000                              # Hostinger will set this automatically — keep as fallback
# NODE_OPTIONS='--max-old-space-size=1024'  # Optional — uncomment if memory pressure on Hostinger

# ------------------------------------------------
# The following are NOT env vars — they are configured
# from the Admin panel (Settings > Analytics / SEO):
#   Meta Pixel ID
#   Google Analytics 4 (GA4) Measurement ID
#   Google Search Console verification code
#   GSTIN (on brand settings)
# ------------------------------------------------
